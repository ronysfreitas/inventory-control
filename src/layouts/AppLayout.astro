---
import '../styles/app.scss';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  databaseReady?: boolean;
}

const appName = import.meta.env.PUBLIC_APP_NAME?.trim() || 'Estoque';
const appShortName =
  import.meta.env.PUBLIC_APP_SHORT_NAME?.trim() ||
  appName
    .split(/\s+/)
    .map((word) => word[0]?.toUpperCase() ?? '')
    .join('')
    .slice(0, 2) ||
  'ES';
const appTagline = import.meta.env.PUBLIC_APP_TAGLINE?.trim() || 'Gestão de estoque';

const {
  title,
  description = `Sistema de estoque ${appName}`,
  currentPath = '/',
  databaseReady = true
} = Astro.props;

const navItems = [
  { href: '/', label: 'Dashboard' },
  { href: '/produtos', label: 'Produtos' },
  { href: '/fornecedores', label: 'Fornecedores' }
];
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | {appName}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a href="/" class="brand">
          <span class="brand-mark">{appShortName}</span>
          <span class="brand-copy">
            <strong>{appName}</strong>
            <small>{appTagline}</small>
          </span>
        </a>

        <nav class="site-nav" aria-label="Navegação principal">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={{
                  'nav-link': true,
                  'nav-link--active': currentPath === item.href
                }}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>

      {
        !databaseReady && (
          <aside class="setup-banner">
            Alguns dados ainda não estão disponíveis no momento.
          </aside>
        )
      }

      <main class="page-content">
        <slot />
      </main>

      <footer class="site-footer">
        <p></p>
      </footer>
    </div>
  </body>
</html>
