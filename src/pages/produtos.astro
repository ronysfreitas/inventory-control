---
import '../styles/catalog-management.scss';

import AppLayout from '../layouts/AppLayout.astro';
import CodeSearchForm from '../components/CodeSearchForm.tsx';
import CreateProductForm from '../components/CreateProductForm.tsx';
import DeleteRecordButton from '../components/DeleteRecordButton.tsx';
import StatusChip from '../components/StatusChip.astro';
import { formatDate, formatQuantity } from '../lib/formatters';
import {
  getProductCatalogData,
  getProductForEditing,
  summarizeProductBalance
} from '../lib/server/inventory-service';

const createParam = Astro.url.searchParams.get('novo');
const editParam = Astro.url.searchParams.get('editar');
const editId = editParam && /^\d+$/.test(editParam) ? Number(editParam) : null;
const createRequested = createParam === '1';

const [data, editingProduct] = await Promise.all([
  getProductCatalogData(),
  editId ? getProductForEditing(editId) : Promise.resolve(null)
]);

const editRequested = Boolean(editParam);
const editNotFound = editRequested && !editingProduct && data.databaseReady;
const showEditModal = Boolean(editingProduct);
const showCreateModal = createRequested && !showEditModal;

const productEditNote = editingProduct
  ? `Estoque atual: ${formatQuantity(editingProduct.estoqueAtual)}. Ultima entrada: ${formatDate(editingProduct.lastEntryDate)}. Ultima saida: ${formatDate(editingProduct.lastExitDate)}. O saldo continua sendo atualizado por entradas e saidas.`
  : '';
---

<AppLayout
  title="Cadastro de produtos"
  description="Cadastro e catalogo dos itens controlados em estoque."
  currentPath="/produtos"
  databaseReady={data.databaseReady}
>
  <section class="hero-panel hero-grid">
    <div>
      <span class="eyebrow">Cadastro principal</span>
      <h1>Produtos com saldo, minimo e prioridade de reposicao no mesmo fluxo.</h1>
      <p class="body-copy">
        Cada item ja nasce preparado para alimentar o dashboard, a busca por codigo
        e as entradas e saidas operacionais.
      </p>
    </div>

    <div class="hero-actions">
      <CodeSearchForm client:load compact={true} />
    </div>
  </section>

  <section class="stack-grid">
    <article class="card">
      <header class="section-heading">
        <div>
          <h2>Catalogo atual</h2>
          <p>Todos os produtos com leitura rapida de estoque e historico.</p>
        </div>

        <a class="button button--primary" href="/produtos?novo=1">
          Incluir produto
        </a>
      </header>

      {
        data.products.length ? (
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Codigo</th>
                  <th>Produto</th>
                  <th>Saldo atual</th>
                  <th>Status</th>
                  <th>Acoes</th>
                </tr>
              </thead>
              <tbody>
                {data.products.map((product) => (
                  <tr>
                    <td>
                      <a
                        class="table-link"
                        href={`/produto/${encodeURIComponent(product.codigo)}`}
                      >
                        {product.codigo}
                      </a>
                    </td>
                    <td>
                      <div>{product.nome}</div>
                      <div class="muted">{product.unidadeCompra}</div>
                    </td>
                    <td>
                      <strong>{formatQuantity(product.estoqueAtual)}</strong>
                      <div class="muted">{summarizeProductBalance(product)}</div>
                      <div class="muted">Ultima entrada: {formatDate(product.lastEntryDate)}</div>
                    </td>
                    <td>
                      <StatusChip
                        label={product.priority.label}
                        tone={product.priority.tone}
                      />
                    </td>
                    <td>
                      <div class="catalog-actions">
                        <a class="catalog-action-link" href={`/produtos?editar=${product.id}`}>
                          Editar
                        </a>
                        <DeleteRecordButton
                          client:load
                          endpoint={`/api/produtos?id=${product.id}`}
                          resourceLabel={`o produto ${product.codigo}`}
                        />
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="empty-state">
            <p>O catalogo aparecera aqui assim que o primeiro produto for cadastrado.</p>
          </div>
        )
      }
    </article>
  </section>

  {
    showEditModal ? (
      <div class="catalog-modal" role="dialog" aria-modal="true" aria-label="Editar produto">
        <div class="catalog-modal__backdrop">
          <div class="catalog-modal__panel">
            <CreateProductForm
              client:load
              disabled={!data.databaseReady}
              mode="edit"
              initialValues={{
                id: editingProduct?.id,
                codigo: editingProduct?.codigo,
                nome: editingProduct?.nome,
                unidadeCompra: editingProduct?.unidadeCompra,
                estoqueMinimo: editingProduct?.estoqueMinimo
              }}
              successRedirect="/produtos"
              cancelHref="/produtos"
              cancelLabel="Fechar"
              note={productEditNote}
            />
          </div>
        </div>
      </div>
    ) : showCreateModal ? (
      <div class="catalog-modal" role="dialog" aria-modal="true" aria-label="Novo produto">
        <div class="catalog-modal__backdrop">
          <div class="catalog-modal__panel">
            <CreateProductForm
              client:load
              disabled={!data.databaseReady}
              successRedirect="/produtos"
              cancelHref="/produtos"
              cancelLabel="Fechar"
            />
          </div>
        </div>
      </div>
    ) : editNotFound ? (
      <div class="catalog-modal" role="dialog" aria-modal="true" aria-label="Produto nao encontrado">
        <div class="catalog-modal__backdrop">
          <article class="catalog-modal__panel card">
            <div class="card__header">
              <div>
                <h2>Produto nao encontrado</h2>
                <p>O registro selecionado para edicao nao esta mais disponivel.</p>
              </div>
              <a href="/produtos" class="button button--secondary">Fechar</a>
            </div>
          </article>
        </div>
      </div>
    ) : null
  }
</AppLayout>
