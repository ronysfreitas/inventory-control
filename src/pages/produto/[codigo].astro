---
import { format as formatDateFns } from 'date-fns';

import AppLayout from '../../layouts/AppLayout.astro';
import ChartCard from '../../components/ChartCard.tsx';
import CodeSearchForm from '../../components/CodeSearchForm.tsx';
import MetricCard from '../../components/MetricCard.astro';
import MovementForm from '../../components/MovementForm.tsx';
import StatusChip from '../../components/StatusChip.astro';
import {
  formatCoverage,
  formatCurrency,
  formatDate,
  formatDateLong,
  formatQuantity
} from '../../lib/formatters';
import { getProductDetailsData } from '../../lib/server/inventory-service';

const codigo = Astro.params.codigo ?? '';
const data = await getProductDetailsData(codigo);
const product = data.product;
const today = formatDateFns(new Date(), 'yyyy-MM-dd');

const totalEntradas = data.entriesLast90Days.reduce((sum, item) => sum + item.quantidade, 0);
const totalSaidas = data.exitsLast90Days.reduce((sum, item) => sum + item.quantidade, 0);
const totalInvestido = data.entriesLast90Days.reduce((sum, item) => sum + item.valorTotal, 0);

const movementConfig = {
  type: 'line',
  data: {
    labels: data.movementSeries.map((item) =>
      item.day.slice(5).split('-').reverse().join('/')
    ),
    datasets: [
      {
        label: 'Entradas',
        data: data.movementSeries.map((item) => item.entradas),
        borderColor: '#0f6165',
        backgroundColor: 'rgba(15, 97, 101, 0.18)',
        tension: 0.3,
        fill: true
      },
      {
        label: 'SaÃ­das',
        data: data.movementSeries.map((item) => item.saidas),
        borderColor: '#b35e2e',
        backgroundColor: 'rgba(179, 94, 46, 0.1)',
        tension: 0.3,
        fill: true
      }
    ]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {
        position: 'bottom'
      }
    },
    scales: {
      y: {
        beginAtZero: true
      }
    }
  }
};

const supplierConfig = {
  type: 'bar',
  data: {
    labels: data.suppliersLastYear.map((item) => item.nome),
    datasets: [
      {
        label: 'Quantidade fornecida',
        data: data.suppliersLastYear.map((item) => item.totalQuantidade),
        backgroundColor: '#0f6165',
        borderRadius: 8
      }
    ]
  },
  options: {
    indexAxis: 'y',
    responsive: true,
    plugins: {
      legend: {
        display: false
      }
    },
    scales: {
      x: {
        beginAtZero: true
      }
    }
  }
};

const stockConfig = {
  type: 'bar',
  data: {
    labels: ['PosiÃ§Ã£o atual'],
    datasets: [
      {
        label: 'Estoque atual',
        data: [product?.estoqueAtual ?? 0],
        backgroundColor: '#0f6165',
        borderRadius: 8
      },
      {
        label: 'Estoque mÃ­nimo',
        data: [product?.estoqueMinimo ?? 0],
        backgroundColor: '#d97a0d',
        borderRadius: 8
      },
      {
        label: 'Estoque regular',
        data: [product?.estoqueRegular ?? 0],
        backgroundColor: '#bea039',
        borderRadius: 8
      }
    ]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {
        position: 'bottom'
      }
    },
    scales: {
      y: {
        beginAtZero: true
      }
    }
  }
};
---

<AppLayout
  title={product ? `${product.codigo} - ${product.nome}` : 'Detalhe do produto'}
  description="Consulta operacional do produto por cÃ³digo com histÃ³rico, grÃ¡ficos e lanÃ§amentos."
  databaseReady={data.databaseReady}
>
  {
    product ? (
      <>
        <section class="product-hero">
          <div class="meta-row">
            <span class="eyebrow">Consulta por cÃ³digo</span>
            <StatusChip label={product.priority.label} tone={product.priority.tone} />
          </div>

          <div class="hero-grid">
            <div>
              <h1>{product.nome}</h1>
              <p class="body-copy">
                CÃ³digo <strong>{product.codigo}</strong> com leitura operacional completa para
                entradas, saÃ­das e tomada de decisÃ£o de compra.
              </p>

              <div class="meta-row">
                <span class="meta-pill">{product.unidadeCompra}</span>
                <span class="meta-pill">
                  Cobertura atual: {formatCoverage(product.priority.coverage)}
                </span>
                <span class="meta-pill">
                  Estoque regular: {formatQuantity(product.estoqueRegular)}
                </span>
                <span class="meta-pill">Ãšltima entrada: {formatDate(product.lastEntryDate)}</span>
                <span class="meta-pill">Ãšltima saÃ­da: {formatDate(product.lastExitDate)}</span>
              </div>
            </div>

            <div class="hero-actions">
              <CodeSearchForm client:load initialValue={product.codigo} compact={true} />
            </div>
          </div>
        </section>

        <section class="metrics-grid">
          <MetricCard
            label="Estoque atual"
            value={formatQuantity(product.estoqueAtual)}
            detail={`Minimo ${formatQuantity(product.estoqueMinimo)} e regular ${formatQuantity(product.estoqueRegular)}.`}
            tone={product.priority.tone}
          />
          <MetricCard
            label="Entradas nos Ãºltimos 90 dias"
            value={formatQuantity(totalEntradas)}
            detail={`Investimento acumulado: ${formatCurrency(totalInvestido)}.`}
            tone="medium"
          />
          <MetricCard
            label="SaÃ­das nos Ãºltimos 90 dias"
            value={formatQuantity(totalSaidas)}
            detail={`Saldo lÃ­quido recente: ${formatQuantity(totalEntradas - totalSaidas)}.`}
            tone="high"
          />
          <MetricCard
            label="Fornecedores ativos no ano"
            value={`${data.suppliersLastYear.length}`}
            detail="Ranking alimentado automaticamente a partir das entradas."
            tone="low"
          />
        </section>

        <section class="split-grid">
          <MovementForm
            client:load
            type="entrada"
            productCode={product.codigo}
            suppliers={data.availableSuppliers}
            disabled={!data.databaseReady}
            today={today}
          />

          <MovementForm
            client:load
            type="saida"
            productCode={product.codigo}
            disabled={!data.databaseReady}
            today={today}
          />
        </section>

        <section class="stack-grid">
          <ChartCard
            client:load
            title="Entradas x saÃ­das em 90 dias"
            description="Fluxo diÃ¡rio do produto no perÃ­odo recente."
            config={movementConfig}
            hasData={data.movementSeries.length > 0}
          />

          <ChartCard
            client:load
            title="Estoque atual comparado aos niveis"
            description="Leitura objetiva frente ao mínimo e ao regular."
            config={stockConfig}
            hasData={true}
          />
        </section>

        <section class="stack-grid">
          <article class="card">
            <header class="section-heading">
              <div>
                <h2>Entradas dos Ãºltimos 90 dias</h2>
                <p>Inclui fornecedor, quantidade, valor unitÃ¡rio e total.</p>
              </div>
            </header>

            {
              data.entriesLast90Days.length ? (
                <div class="table-wrapper">
                  <table>
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Data</th>
                        <th>Fornecedor</th>
                        <th>Quantidade</th>
                        <th>Valor unitÃ¡rio</th>
                        <th>Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      {data.entriesLast90Days.map((entry) => (
                        <tr>
                          <td>{entry.id}</td>
                          <td>{formatDate(entry.data)}</td>
                          <td>
                            <div>{entry.fornecedorNome}</div>
                            <div class="muted">{entry.observacao ?? 'Sem observaÃ§Ã£o'}</div>
                          </td>
                          <td>{formatQuantity(entry.quantidade)}</td>
                          <td>{formatCurrency(entry.valorUnitario)}</td>
                          <td>{formatCurrency(entry.valorTotal)}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : (
                <div class="empty-state">
                  <p>As prÃ³ximas entradas deste item aparecerÃ£o aqui automaticamente.</p>
                </div>
              )
            }
          </article>

          <article class="card">
            <header class="section-heading">
              <div>
                <h2>SaÃ­das dos Ãºltimos 90 dias</h2>
                <p>MovimentaÃ§Ãµes recentes de consumo ou expediÃ§Ã£o.</p>
              </div>
            </header>

            {
              data.exitsLast90Days.length ? (
                <div class="table-wrapper">
                  <table>
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Data</th>
                        <th>Quantidade</th>
                        <th>ObservaÃ§Ã£o</th>
                      </tr>
                    </thead>
                    <tbody>
                      {data.exitsLast90Days.map((exit) => (
                        <tr>
                          <td>{exit.id}</td>
                          <td>{formatDate(exit.data)}</td>
                          <td>{formatQuantity(exit.quantidade)}</td>
                          <td>{exit.observacao ?? 'Sem observaÃ§Ã£o'}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : (
                <div class="empty-state">
                  <p>As saÃ­das registradas para este produto serÃ£o listadas aqui.</p>
                </div>
              )
            }
          </article>
        </section>

        <section class="stack-grid">
          <article class="card">
            <header class="section-heading">
              <div>
                <h2>Maiores fornecedores no Ãºltimo ano</h2>
                <p>Ranking por quantidade total entregue deste produto.</p>
              </div>
            </header>

            {
              data.suppliersLastYear.length ? (
                <div class="table-wrapper">
                  <table>
                    <thead>
                      <tr>
                        <th>Fornecedor</th>
                        <th>Quantidade total</th>
                        <th>Entradas</th>
                        <th>Ãšltima entrega</th>
                      </tr>
                    </thead>
                    <tbody>
                      {data.suppliersLastYear.map((supplier) => (
                        <tr>
                          <td>{supplier.nome}</td>
                          <td>{formatQuantity(supplier.totalQuantidade)}</td>
                          <td>{supplier.totalEntradas}</td>
                          <td>{formatDateLong(supplier.ultimaEntrega)}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : (
                <div class="empty-state">
                  <p>O ranking serÃ¡ gerado automaticamente quando houver entradas deste produto.</p>
                </div>
              )
            }
          </article>

          <ChartCard
            client:load
            title="ParticipaÃ§Ã£o dos fornecedores"
            description="Volume anual entregue para este produto."
            config={supplierConfig}
            hasData={data.suppliersLastYear.length > 0}
          />
        </section>
      </>
    ) : (
      <section class="hero-panel hero-grid">
        <div>
          <span class="eyebrow">Produto nÃ£o encontrado</span>
          <h1>Nenhum item foi localizado para o cÃ³digo {codigo || 'informado'}.</h1>
          <p class="body-copy">
            Verifique o cÃ³digo digitado ou use a busca abaixo para localizar outro produto.
          </p>
        </div>
        <div class="hero-actions">
          <CodeSearchForm client:load initialValue={codigo} />
        </div>
      </section>
    )
  }
</AppLayout>


