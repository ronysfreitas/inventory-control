---
import '../styles/catalog-management.scss';

import AppLayout from '../layouts/AppLayout.astro';
import CreateSupplierForm from '../components/CreateSupplierForm.tsx';
import DeleteRecordButton from '../components/DeleteRecordButton.tsx';
import {
  getSupplierCatalogData,
  getSupplierForEditing
} from '../lib/server/inventory-service';

const createParam = Astro.url.searchParams.get('novo');
const editParam = Astro.url.searchParams.get('editar');
const editId = editParam && /^\d+$/.test(editParam) ? Number(editParam) : null;
const createRequested = createParam === '1';

const [data, editingSupplier] = await Promise.all([
  getSupplierCatalogData(),
  editId ? getSupplierForEditing(editId) : Promise.resolve(null)
]);

const editRequested = Boolean(editParam);
const editNotFound = editRequested && !editingSupplier && data.databaseReady;
const showEditModal = Boolean(editingSupplier);
const showCreateModal = createRequested && !showEditModal;

const supplierEditNote = editingSupplier
  ? editingSupplier.totalEntradas > 0
    ? `Este fornecedor já possui ${editingSupplier.totalEntradas} entradas registradas. As alterações afetam apenas os dados cadastrais.`
    : 'Este fornecedor ainda não possui entradas registradas.'
  : '';
---

<AppLayout
  title="Cadastro de fornecedores"
  description="Cadastro e consulta dos fornecedores usados nas entradas do estoque."
  currentPath="/fornecedores"
  databaseReady={data.databaseReady}
>
  <section class="hero-panel">
    <span class="eyebrow">Rede de abastecimento</span>
    <h1>Fornecedores | Cadastro e atualizações</h1>
    <p class="body-copy">
      O cadastro apoia o lançamento das entradas e facilita a consulta dos parceiros.
    </p>
  </section>

  <section class="stack-grid">
    <article class="card">
      <header class="section-heading">
        <div>
          <h2>Fornecedores cadastrados</h2>
          <p>Contatos, e-mails e histórico de entradas por fornecedor.</p>
        </div>

        <a class="button button--primary" href="/fornecedores?novo=1">
          Incluir fornecedor
        </a>
      </header>

      {
        data.suppliers.length ? (
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Fornecedor</th>
                  <th>Contatos</th>
                  <th>E-mail</th>
                  <th>Histórico</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                {data.suppliers.map((supplier) => (
                  <tr>
                    <td>{supplier.nome}</td>
                    <td>
                      <div>{supplier.contato1 ?? 'Sem contato principal'}</div>
                      <div class="muted">{supplier.contato2 ?? 'Sem contato secundário'}</div>
                    </td>
                    <td>{supplier.email ?? 'Sem e-mail informado'}</td>
                    <td>
                      <div>{supplier.totalEntradas} entradas registradas</div>
                    </td>
                    <td>
                      <div class="catalog-actions">
                        <a
                          class="catalog-action-link"
                          href={`/fornecedores?editar=${supplier.id}`}
                        >
                          Editar
                        </a>
                        <DeleteRecordButton
                          client:load
                          endpoint={`/api/fornecedores?id=${supplier.id}`}
                          resourceLabel={`o fornecedor ${supplier.nome}`}
                        />
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="empty-state">
            <p>Cadastre fornecedores para habilitar o lançamento de entradas.</p>
          </div>
        )
      }
    </article>
  </section>

  {
    showEditModal ? (
      <div class="catalog-modal" role="dialog" aria-modal="true" aria-label="Editar fornecedor">
        <div class="catalog-modal__backdrop">
          <div class="catalog-modal__panel">
            <CreateSupplierForm
              client:load
              disabled={!data.databaseReady}
              mode="edit"
              initialValues={{
                id: editingSupplier?.id,
                nome: editingSupplier?.nome,
                contato1: editingSupplier?.contato1,
                contato2: editingSupplier?.contato2,
                email: editingSupplier?.email
              }}
              successRedirect="/fornecedores"
              cancelHref="/fornecedores"
              cancelLabel="Fechar"
              note={supplierEditNote}
            />
          </div>
        </div>
      </div>
    ) : showCreateModal ? (
      <div class="catalog-modal" role="dialog" aria-modal="true" aria-label="Novo fornecedor">
        <div class="catalog-modal__backdrop">
          <div class="catalog-modal__panel">
            <CreateSupplierForm
              client:load
              disabled={!data.databaseReady}
              successRedirect="/fornecedores"
              cancelHref="/fornecedores"
              cancelLabel="Fechar"
            />
          </div>
        </div>
      </div>
    ) : editNotFound ? (
      <div class="catalog-modal" role="dialog" aria-modal="true" aria-label="Fornecedor não encontrado">
        <div class="catalog-modal__backdrop">
          <article class="catalog-modal__panel card">
            <div class="card__header">
              <div>
                <h2>Fornecedor não encontrado</h2>
                <p>O registro selecionado para edição não está mais disponível.</p>
              </div>
              <a href="/fornecedores" class="button button--secondary">Fechar</a>
            </div>
          </article>
        </div>
      </div>
    ) : null
  }
</AppLayout>
