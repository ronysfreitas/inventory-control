---
import '../styles/catalog-management.scss';

import AppLayout from '../layouts/AppLayout.astro';
import CreateSupplierForm from '../components/CreateSupplierForm.tsx';
import DeleteRecordButton from '../components/DeleteRecordButton.tsx';
import {
  getSupplierCatalogData,
  getSupplierForEditing
} from '../lib/server/inventory-service';

const editParam = Astro.url.searchParams.get('editar');
const editId = editParam && /^\d+$/.test(editParam) ? Number(editParam) : null;

const [data, editingSupplier] = await Promise.all([
  getSupplierCatalogData(),
  editId ? getSupplierForEditing(editId) : Promise.resolve(null)
]);

const editRequested = Boolean(editParam);
const editNotFound = editRequested && !editingSupplier && data.databaseReady;

const supplierEditNote = editingSupplier
  ? editingSupplier.totalEntradas > 0
    ? `Este fornecedor ja possui ${editingSupplier.totalEntradas} entradas registradas. As alteracoes afetam apenas os dados cadastrais.`
    : 'Este fornecedor ainda nao possui entradas registradas.'
  : '';
---

<AppLayout
  title="Cadastro de fornecedores"
  description="Cadastro e consulta dos fornecedores usados nas entradas do estoque."
  currentPath="/fornecedores"
  databaseReady={data.databaseReady}
>
  <section class="hero-panel">
    <span class="eyebrow">Rede de abastecimento</span>
    <h1>Fornecedores centralizados para agilizar entradas e organizar contatos.</h1>
    <p class="body-copy">
      O cadastro apoia o lancamento das entradas e facilita a consulta dos parceiros.
    </p>
  </section>

  <section class="stack-grid">
    {
      editingSupplier ? (
        <CreateSupplierForm
          client:load
          disabled={!data.databaseReady}
          mode="edit"
          initialValues={{
            id: editingSupplier.id,
            nome: editingSupplier.nome,
            contato1: editingSupplier.contato1,
            contato2: editingSupplier.contato2,
            email: editingSupplier.email
          }}
          successRedirect="/fornecedores"
          cancelHref="/fornecedores"
          cancelLabel="Encerrar edicao"
          note={supplierEditNote}
        />
      ) : editNotFound ? (
        <article class="card">
          <div class="empty-state">
            <p>O fornecedor selecionado para edicao nao foi encontrado.</p>
          </div>
        </article>
      ) : null
    }

    <CreateSupplierForm client:load disabled={!data.databaseReady} />

    <article class="card">
      <header class="section-heading">
        <div>
          <h2>Fornecedores cadastrados</h2>
          <p>Contatos, e-mails e historico de entradas por fornecedor.</p>
        </div>
      </header>

      {
        data.suppliers.length ? (
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Fornecedor</th>
                  <th>Contatos</th>
                  <th>E-mail</th>
                  <th>Historico</th>
                  <th>Acoes</th>
                </tr>
              </thead>
              <tbody>
                {data.suppliers.map((supplier) => (
                  <tr>
                    <td>{supplier.nome}</td>
                    <td>
                      <div>{supplier.contato1 ?? 'Sem contato principal'}</div>
                      <div class="muted">{supplier.contato2 ?? 'Sem contato secundario'}</div>
                    </td>
                    <td>{supplier.email ?? 'Sem e-mail informado'}</td>
                    <td>
                      <div>{supplier.totalEntradas} entradas registradas</div>
                    </td>
                    <td>
                      <div class="catalog-actions">
                        <a
                          class="catalog-action-link"
                          href={`/fornecedores?editar=${supplier.id}`}
                        >
                          Editar
                        </a>
                        <DeleteRecordButton
                          client:load
                          endpoint={`/api/fornecedores?id=${supplier.id}`}
                          resourceLabel={`o fornecedor ${supplier.nome}`}
                        />
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="empty-state">
            <p>Cadastre fornecedores para habilitar o lancamento de entradas.</p>
          </div>
        )
      }
    </article>
  </section>
</AppLayout>
